{
  "name": "bolusi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "task:status": "node scripts/task-status.mjs",
    "typecheck": "tsc -b && pnpm -r typecheck",
    "lint": "eslint .",
    "i18n:check": "pnpm --filter @bolusi/i18n i18n:check",
    "knip": "node scripts/check-unused-exports.mjs",
    "knip:baseline": "node scripts/check-unused-exports.mjs --update",
    "sweep:exports": "knip --production --include exports --no-progress",
    "sweep:exports:all": "knip --include exports --no-progress",
    "test": "tsc -b && vitest run",
    "test:jcs-hermes": "node scripts/hermes-vectors/run.mjs",
    "test:ed25519-interop": "tsc -b && vitest run --project test-support src/crypto/noble-port.test.ts",
    "falsify:crypto": "node scripts/falsify-guards.mjs",
    "test:server": "tsc -b && vitest run --project server",
    "test:rls": "tsc -b && vitest run --project db-server",
    "test:appliers": "tsc -b && vitest run --project core test/module/applier-conformance.test.ts",
    "chaos": "tsc -b && vitest run --project harness",
    "sec:sweep": "node scripts/sec-sweep.mjs",
    "sec:inventory": "node scripts/sec-inventory.mjs",
    "sec:secrets": "node scripts/secrets-scan.mjs",
    "sec:deps": "node scripts/dependency-audit.mjs",
    "test:security": "tsc -b && vitest run --config packages/harness/vitest.security.config.ts",
    "chaos:nightly": "tsc -b && CHAOS_NIGHTLY=1 CHAOS_SCALE=4 vitest run --project harness",
    "simulate": "node scripts/not-implemented.mjs simulate 26-chaos-harness",
    "db:up": "node scripts/db-lane.mjs --up",
    "db:down": "node scripts/db-lane.mjs --down",
    "db:url": "node scripts/db-lane.mjs --db=bolusi_dev --url",
    "db:stamp": "pnpm --filter @bolusi/db-server db:stamp",
    "db:migrate": "node scripts/db-lane.mjs --db=bolusi_dev -- pnpm --filter @bolusi/db-server db:migrate",
    "db:seed": "node scripts/not-implemented.mjs db:seed 05-db-server",
    "db:codegen": "node scripts/db-lane.mjs --db=bolusi_dev -- pnpm --filter @bolusi/db-server db:codegen",
    "db:codegen:check": "node scripts/db-lane.mjs --db=bolusi_dev -- pnpm --filter @bolusi/db-server db:codegen:check",
    "dev": "pnpm run \"/^dev:/\"",
    "dev:tsc": "tsc -b --watch --preserveWatchOutput",
    "dev:server": "pnpm --filter @bolusi/server dev",
    "dev:mobile": "pnpm --filter @bolusi/mobile dev"
  },
  "devDependencies": {
    "@bolusi/eslint-config": "workspace:*",
    "@bolusi/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "esbuild": "catalog:",
    "hermes-compiler": "250829098.0.14"
  },
  "pnpm": {
    "overrides": {
      "zod": "4.4.3"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  }
}
