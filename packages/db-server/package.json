{
  "name": "@bolusi/db-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Kysely + PostgresDialect, migrations, codegen types, RLS policies, forTenant — the ONLY exported way to query tenant tables (08 §3.2, FR-1039)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "db:migrate": "kysely migrate latest",
    "db:codegen": "kysely-codegen --dialect postgres --camel-case --out-file src/generated/db.d.ts --url ${DATABASE_URL:-postgres://bolusi:bolusi@localhost:5432/bolusi_dev}",
    "db:codegen:check": "kysely-codegen --dialect postgres --camel-case --out-file src/generated/db.d.ts --url ${DATABASE_URL:-postgres://bolusi:bolusi@localhost:5432/bolusi_dev} --verify",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bolusi/core": "workspace:*",
    "@bolusi/schemas": "workspace:*",
    "kysely": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@bolusi/eslint-config": "workspace:*",
    "@bolusi/tsconfig": "workspace:*",
    "@electric-sql/pglite": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "eslint": "catalog:",
    "kysely-codegen": "catalog:",
    "kysely-ctl": "catalog:"
  }
}
