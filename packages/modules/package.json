{
  "name": "@bolusi/modules",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "defineModule manifests (04-module-contract). Split exports: ./notes = platform-free manifest, ./notes/screens = RN (08 §3.2)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./notes": {
      "types": "./dist/notes/index.d.ts",
      "default": "./dist/notes/index.js"
    },
    "./notes/screens": {
      "types": "./dist/notes/screens/index.d.ts",
      "default": "./dist/notes/screens/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@bolusi/core": "workspace:*",
    "@bolusi/schemas": "workspace:*",
    "@bolusi/i18n": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bolusi/db-client": "workspace:*",
    "@bolusi/test-support": "workspace:*",
    "@bolusi/tsconfig": "workspace:*",
    "@electric-sql/pglite": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "better-sqlite3": "catalog:",
    "kysely": "catalog:"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsc -b ../db-client/tsconfig.build.json ../test-support/tsconfig.build.json && vitest run"
  }
}
