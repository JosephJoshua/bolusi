{
  "name": "@bolusi/modules",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "defineModule manifests (04-module-contract). Split exports: ./notes = platform-free manifest, ./notes/screens = RN (08 §3.2)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./notes": {
      "types": "./dist/notes/index.d.ts",
      "default": "./dist/notes/index.js"
    },
    "./notes/screens": {
      "types": "./dist/notes/screens/index.d.ts",
      "default": "./dist/notes/screens/index.js"
    },
    "./notes/i18n/id.json": "./notes/i18n/id.json",
    "./notes/i18n/en.json": "./notes/i18n/en.json"
  },
  "files": [
    "dist",
    "notes/i18n"
  ],
  "dependencies": {
    "@bolusi/core": "workspace:*",
    "@bolusi/schemas": "workspace:*",
    "@bolusi/i18n": "workspace:*",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@bolusi/ui": "workspace:*",
    "expo-image": ">=57",
    "react": ">=19",
    "react-native": ">=0.86"
  },
  "devDependencies": {
    "@bolusi/db-client": "workspace:*",
    "@bolusi/test-support": "workspace:*",
    "@bolusi/tsconfig": "workspace:*",
    "@bolusi/ui": "workspace:*",
    "@electric-sql/pglite": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "19.2.17",
    "better-sqlite3": "catalog:",
    "expo-image": "57.0.0",
    "kysely": "catalog:",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsc -b ../db-client/tsconfig.build.json ../test-support/tsconfig.build.json ../i18n/tsconfig.build.json ../ui/tsconfig.build.json && vitest run"
  }
}
