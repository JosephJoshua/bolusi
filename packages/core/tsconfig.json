{
  "extends": "@bolusi/tsconfig/base.json",
  "compilerOptions": {
    "noEmit": true,
    // Tests import the committed tamper fixtures as JSON (test/oplog/fixtures/tamper/*),
    // keeping the loader platform-free (no node:fs). Typecheck-only: the build config
    // (tsconfig.build.json) excludes test/ and src imports no JSON.
    "resolveJsonModule": true
  },
  "include": ["src", "test"]
}
