{
  "name": "@bolusi/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Op log, projection engine, command runtime, sync client core, JCS, UUIDv7 — PURE TS, all effects behind ports (08 §3.2)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@bolusi/schemas": "workspace:*",
    "canonicalize": "catalog:",
    "kysely": "catalog:"
  },
  "devDependencies": {
    "@bolusi/db-client": "workspace:*",
    "@bolusi/tsconfig": "workspace:*",
    "@bolusi/test-support": "workspace:*",
    "@types/better-sqlite3": "catalog:",
    "better-sqlite3": "catalog:"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsc -b ../db-client/tsconfig.build.json ../test-support/tsconfig.build.json && vitest run"
  }
}
