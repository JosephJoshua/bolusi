{
  "name": "@bolusi/db-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "op-sqlite wrapper (the ONLY importer of @op-engineering/op-sqlite) + custom Kysely dialect; expo-sqlite stays a swap target (08 §3.2)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./op-sqlite": {
      "types": "./dist/adapters/op-sqlite.d.ts",
      "default": "./dist/adapters/op-sqlite.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@bolusi/core": "workspace:*",
    "@bolusi/schemas": "workspace:*",
    "@op-engineering/op-sqlite": "catalog:",
    "kysely": "catalog:",
    "kysely-generic-sqlite": "catalog:"
  },
  "devDependencies": {
    "@bolusi/test-support": "workspace:*",
    "@bolusi/tsconfig": "workspace:*",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "better-sqlite3": "catalog:",
    "kysely-codegen": "catalog:",
    "tsx": "catalog:"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "db:codegen": "tsx scripts/codegen.ts",
    "test": "tsc -b ../.. && vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  }
}
