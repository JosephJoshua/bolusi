    "propertySorting": {
      "$source": "RFC 8785 §3.2.3 sorting test data",
      "$note": "Property names sort as arrays of UTF-16 code units. expectedValueOrder lists the VALUES in the order their keys must appear once sorted.",
      "input": {
        "€": "Euro Sign",
        "\r": "Carriage Return",
        "דּ": "Hebrew Letter Dalet With Dagesh",
        "1": "One",
        "😀": "Emoji: Grinning Face",
        "": "Control",
        "ö": "Latin Small Letter O With Diaeresis"
      },
      "expectedValueOrder": [
        "Carriage Return",
        "One",
        "Control",
        "Latin Small Letter O With Diaeresis",
        "Euro Sign",
        "Emoji: Grinning Face",
        "Hebrew Letter Dalet With Dagesh"
      ]
    }
