    "numberSerialization": {
      "$source": "RFC 8785 Appendix B, Table 1",
      "$note": "ieee754 = big-endian hex of the IEEE 754 binary64 value. expected = null means a compliant JCS implementation MUST terminate with an error (NaN and Infinity are not valid JSON).",
      "vectors": [
