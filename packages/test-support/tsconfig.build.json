{
  "extends": "@bolusi/tsconfig/node.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"],
  "references": [
    {
      "path": "../core/tsconfig.build.json"
    },
    {
      "path": "../schemas/tsconfig.build.json"
    },
    {
      // Type-only: the driver-conformance suite is typed against db-client's `DbDriver`,
      // the ONE driver interface. No runtime edge — `verbatimModuleSyntax` + the
      // type-only import keep db-client out of this package's emitted JS.
      "path": "../db-client/tsconfig.build.json"
    }
  ]
}
