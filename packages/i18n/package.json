{
  "name": "@bolusi/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "i18next + ICU label catalogs, locale state, Intl formatters, CI gates (07-i18n)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@bolusi/schemas": "workspace:*",
    "i18next": "catalog:",
    "i18next-icu": "catalog:",
    "intl-messageformat": "catalog:"
  },
  "devDependencies": {
    "@bolusi/tsconfig": "workspace:*",
    "@formatjs/icu-messageformat-parser": "catalog:",
    "@types/node": "catalog:",
    "prettier": "catalog:"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "i18n:seed": "node scripts/seed.mjs",
    "i18n:gen": "node scripts/gen.mjs",
    "i18n:check": "node scripts/check.mjs"
  }
}
