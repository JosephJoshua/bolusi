{
  "extends": "@bolusi/tsconfig/base.json",
  "compilerOptions": {
    "noEmit": true,
    // The gate suites import the JSDoc-typed scripts/*.mjs. `checkJs` stays off: the scripts are
    // JS on purpose (repo convention, see scripts/check-forbidden-packages.mjs) and are covered
    // by their own fixtures, but tsc still infers their exported signatures for the tests.
    "allowJs": true,
    // Node types are for the gate suites (node:fs) only. This does NOT loosen the platform-free
    // lock on shipped code: tsconfig.build.json is what `tsc -b` compiles and it keeps the base
    // `types: []` over `src` alone, and bolusi/boundaries still forbids node:* imports in src.
    "types": ["node"]
  },
  // `test` is typechecked but never built — tsconfig.build.json keeps rootDir=src, which is the
  // platform-free lock (08 §3.4). The @ts-expect-error key-typo fixture only means something if
  // the test tree is actually typechecked.
  "include": ["src", "test"]
}
